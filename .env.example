# codex-unison environment variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# Required: your Unison API key (usk_live_...)
# Obtain one via: npx codex-unison install  (browser flow)
# Or headless: curl -X POST https://api.unisonlabs.ai/v1/auth/provision -d '{"email":"you@example.com"}'
UNISON_TOKEN=

# Optional: override the Unison API base URL (default: https://api.unisonlabs.ai)
UNISON_API_URL=

# Optional: override the Unison app URL for browser auth (default: https://app.unisonlabs.ai)
UNISON_APP_URL=

# Optional: enable debug logging to ~/.codex-unison.log
UNISON_DEBUG=
